# ==================== 数据文件 ====================
# 原始数据（通常极大，不应提交）
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.parquet
data/raw/*.json
# 中间数据和处理后的数据（由代码生成，不需要版本控制）
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
# ==================== Python ====================
# 缓存文件
__pycache__/
*.py[cod]
*$py.class
*.so
# 虚拟环境 / Conda
.venv/
env/
venv/
*.egg-info/
dist/
build/
# Jupyter
.ipynb_checkpoints/
